# Copy to ".env" in this directory. Docker Compose reads it for ${VAR} substitution in docker-compose.yml.
# Restart the api container after changing values: docker compose up -d --build api

# Google OAuth (Web application client) — required for "Sign in with Google"
# Authorized redirect URI (exact): http://localhost:3100/auth/google_oauth2/callback
# Authorized JavaScript origins can include: http://localhost:3000 and http://localhost:3100
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional
GEMINI_API_KEY=
